{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "pampam-clone",
  "projectType": "application",
  "root": "apps/pampam-clone",
  "sourceRoot": "apps/pampam-clone/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build --workspace=apps/pampam-clone"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint --workspace=apps/pampam-clone"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev --workspace=apps/pampam-clone"
      }
    }
  }
}

{
  "name": "example-apps",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "nx affected -t build",
    "build:all": "nx run-many -t build --all",
    "deploy:affected": "node tools/netlify/deploy-affected.mjs --mode production",
    "deploy:previews": "node tools/netlify/deploy-affected.mjs --mode preview",
    "nx": "nx"
  },
  "overrides": {
    "ajv-errors": {
      "ajv": "^8"
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.8.0",
    "netlify-cli": "^26.1.0",
    "nx": "^22.0.0"
  }
}

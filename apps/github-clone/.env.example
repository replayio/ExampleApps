# --- Frontend (Vite) ---
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# --- Netlify Functions: Auth0 ---
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
# Set to "true" to run the API without auth (local dev before .env is provisioned)
# AUTH_DISABLED=true

# --- Cloudflare R2 (S3-compatible credentials) ---
CLOUDFLARE_API_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=github-clone

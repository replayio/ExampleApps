# --- Frontend (Vite) ---
VITE_AUTH0_DOMAIN=webreplay.us.auth0.com
VITE_AUTH0_CLIENT_ID=
# Optional: set to get a JWT access token instead of an opaque one
VITE_AUTH0_AUDIENCE=

# --- Netlify Functions ---
AUTH0_DOMAIN=webreplay.us.auth0.com
AUTH0_AUDIENCE=

# A hardcoded JWT accepted verbatim as the Bearer token (skips JWKS verification)
AUTH_BYPASS_JWT=

# An Auth0 refresh token for the GitHub Token Vault exchange under bypass
AUTH_BYPASS_REFRESH_TOKEN=
